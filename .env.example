# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Z-API (WhatsApp)
ZAPI_INSTANCE_ID=
ZAPI_TOKEN=
ZAPI_CLIENT_TOKEN=

# OpenAI (Miry agent)
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

# Auth — gerar com: node -e 'console.log(require("crypto").randomBytes(32).toString("hex"))'
# Min 32 chars. Usuários e hashes ficam em lib/users.ts.
SESSION_SECRET=

# Cron — gerar com: node -e 'console.log(require("crypto").randomBytes(24).toString("hex"))'
CRON_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
